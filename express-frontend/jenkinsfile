pipeline {
    agent any

    stages {
        stage('Pull Latest Code') {
            steps {
                sh '''
                sudo -u ubuntu bash -c "cd /home/ubuntu/Assignment8_Terraform_AWS && git pull origin main"
                '''
            }
        }

        stage('Install Express Dependencies') {
            steps {
                sh '''
                sudo -u ubuntu bash -c "cd /home/ubuntu/Assignment8_Terraform_AWS/express-frontend && npm install"
                '''
            }
        }

        stage('Restart Express App') {
            steps {
                sh '''
                sudo -u ubuntu bash -c "pm2 restart express-frontend && pm2 list"
                '''
            }
        }
    }
}
